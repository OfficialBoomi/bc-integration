{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Skill(bc-integration:boomi-integration)",
      "Read(~/.claude/plugins/**)",
      "Bash(bash */skills/boomi-integration/tools/*)",
      "Bash(python3 */skills/boomi-integration/tools/*)",
      "Bash(source:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(grep:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(mkdir:*)",
      "Bash(test:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(which:*)",
      "Bash(env)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Bash(*.env*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git reset:*)"
    ]
  }
}